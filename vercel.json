{
  "buildCommand": "cd frontend && yarn build",
  "installCommand": "cd frontend && yarn install --frozen-lockfile",
  "outputDirectory": "frontend/build",
  "functions": {
    "api/index.py": {
      "maxDuration": 30
    }
  },
  "rewrites": [
    { "source": "/api/:path*", "destination": "/api" }
  ]
}
